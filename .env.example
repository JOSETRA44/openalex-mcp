# OpenAlex API key — free at https://openalex.org/settings/api
OPENALEX_API_KEY=your_api_key_here

# Optional: email for polite pool (faster responses, no key required)
# OPENALEX_EMAIL=your@email.com

# Cache: how long to cache API responses in seconds (0 = disabled)
OPENALEX_CACHE_TTL=300

# Max retries on rate limit / server errors
OPENALEX_MAX_RETRIES=3

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
